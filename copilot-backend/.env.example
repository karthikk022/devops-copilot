OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACK_MODELS=meta-llama/llama-3.1-8b-instruct:free,qwen/qwen-2.5-coder-32b-instruct:free
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

CORS_ORIGINS=http://localhost:3000,http://localhost:8080

PROMETHEUS_URL=http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090
LOKI_URL=http://loki-gateway.monitoring.svc.cluster.local:80

DATABASE_URL=postgresql://copilot:copilot@localhost:5432/copilot
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RAG_TOP_K=4
RAG_SIMILARITY_THRESHOLD=0.35
AUTO_INGEST_RUNBOOKS=true
RUNBOOKS_DIR=./runbooks

K8S_API_URL=
K8S_BEARER_TOKEN=
AGENT_MAX_ITERATIONS=5

LOG_LEVEL=INFO
